<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E65100" /> <!-- Darker Orange/Brown -->
                </shape>
            </item>
            <item android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient 
                        android:angle="270" 
                        android:startColor="#FFB74D" 
                        android:endColor="#F57C00" 
                        android:type="linear"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Default state -->
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E65100" />
                </shape>
            </item>
            <item android:bottom="6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient 
                        android:angle="270" 
                        android:startColor="#FFB74D" 
                        android:endColor="#F57C00" 
                        android:type="linear"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
